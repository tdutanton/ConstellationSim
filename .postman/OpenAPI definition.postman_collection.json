        {
          "name": "overview Copy",
          "item": [
            {
              "name": "overview",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Overview after add returned 200\", () => {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Satellite count increased by at least 1\", () => {\r",
                      "    const data = pm.response.json();\r",
                      "    const initial = parseInt(pm.environment.get(\"initialSatelliteCount\") || \"0\");\r",
                      "    const current = Array.isArray(data) ? data.length : 0;\r",
                      "    \r",
                      "    pm.expect(current).to.be.greaterThan(initial);\r",
                      "});"
                    ],
                    "type": "text/javascript",
