        {
          "name": "overview",
          "item": [
            {
              "name": "overview",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Overview returned 200\", () => {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "// 2. Сохраняем начальное количество спутников (подставьте ваше поле из DTO)\r",
                      "const data = pm.response.json();\r",
                      "const initialCount = Array.isArray(data) ? data.length : 0;\r",
                      "pm.environment.set(\"initialSatelliteCount\", initialCount);\r",
                      "\r",
                      "// Опционально: сохраняем имя группировки для следующего шага\r",
                      "if (initialCount > 0) {\r",
                      "    pm.environment.set(\"targetConstellation\", data[0].constellationName); // 👈 замените на реальное поле\r",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "*/*"
